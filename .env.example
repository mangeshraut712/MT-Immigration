# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Vidya Raut Portfolio

# OpenAI Responses API
# Optional: if set, the chatbot will prefer OpenAI's newer Responses API path.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# OpenRouter fallback
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# Optional FastAPI backend for chatbot and other AI features
# Replace this with your deployed FastAPI service URL or use http://127.0.0.1:8000 locally
FASTAPI_URL=
# Optional shared secret between Next.js and FastAPI when you proxy through /api/chat
FASTAPI_INTERNAL_TOKEN=

# Optional upstream chat endpoint for local development when you do not have local AI keys.
# Both Next.js and the optional FastAPI backend can use this.
# Defaults to the live Vercel chatbot backend in non-production if left blank.
CHAT_UPSTREAM_URL=

# Optional direct dev rewrite to FastAPI in next.config.ts.
# Leave blank unless you specifically want /api/* rewritten at the Next.js layer.
FASTAPI_DEV_REWRITE=
