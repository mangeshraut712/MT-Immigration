# Only OpenRouter and optional direct OpenAI fallback are supported by this repo.
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REASONING_EFFORT=low
OPENROUTER_APP_NAME=M&T Immigration
OPENROUTER_SITE_URL=https://mt-immigration.vercel.app
USE_FASTAPI_AGENTS=false
FASTAPI_AGENT_BASE_URL=
FASTAPI_AGENT_SHARED_SECRET=replace_with_a_long_random_secret

# Optional: defaults to false locally and true in production when unset.
AI_BENCH_REVIEW_ENABLED=

# Required in production for shared API rate limiting:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required to accept intake submissions in production:
# forwards validated intake submissions to your CRM, Zapier, Make, or custom webhook.
INTAKE_WEBHOOK_URL=
INTAKE_WEBHOOK_BEARER_TOKEN=
INTAKE_WEBHOOK_SIGNING_SECRET=

# Optional intake confirmation emails via Resend.
RESEND_API_KEY=
INTAKE_CONFIRMATION_FROM_EMAIL=
INTAKE_CONFIRMATION_REPLY_TO=

# Public site URL used for metadata and sitemap generation.
NEXT_PUBLIC_SITE_URL=https://mt-immigration.vercel.app
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_FIRM_NAME=M&T Immigration Law Firm
NEXT_PUBLIC_FIRM_SHORT_NAME=M&T Immigration
NEXT_PUBLIC_FIRM_PHONE_DISPLAY=
NEXT_PUBLIC_FIRM_PHONE_HREF=
NEXT_PUBLIC_FIRM_EMAIL=
NEXT_PUBLIC_FIRM_EMAIL_HREF=
NEXT_PUBLIC_FIRM_CITY=New York, NY
NEXT_PUBLIC_FIRM_REGION_LABEL=Virtual consultations nationwide
NEXT_PUBLIC_FIRM_HOURS=Mon-Fri, 9AM - 6PM EST
NEXT_PUBLIC_FIRM_RESPONSE_TIME=1-2 business days

# Optional direct OpenAI fallback for the Next.js chat route when FastAPI agents are disabled:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_INSIGHTS_MODEL=
OPENAI_INSIGHTS_REASONING_EFFORT=

# Optional: comma-separated extra origins to trust for POST requests (preview URLs, etc.)
TRUSTED_ORIGINS=

# Preferred: keep payment destinations server-side and only expose enabled flags publicly.
STRIPE_CHECKOUT_URL=
PAYPAL_CHECKOUT_URL=
WIRE_TRANSFER_REQUEST_URL=
NEXT_PUBLIC_STRIPE_CHECKOUT_ENABLED=
NEXT_PUBLIC_PAYPAL_CHECKOUT_ENABLED=
NEXT_PUBLIC_WIRE_TRANSFER_REQUEST_ENABLED=

# Legacy public payment URLs are still supported as a fallback.
NEXT_PUBLIC_STRIPE_CHECKOUT_URL=
NEXT_PUBLIC_PAYPAL_CHECKOUT_URL=
NEXT_PUBLIC_WIRE_TRANSFER_REQUEST_URL=
